{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:icon",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:icon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "launchType": "singleton",
        "metadata": [
          {
            // 长按应用图标的快捷方式：快速拍照识别 / 快速导入截图。
            "name": "ohos.ability.shortcuts",
            "resource": "$profile:shortcuts_config"
          }
        ],
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home"
            ]
          },
          {
            // 系统分享接收：作为图片分享目标。收到 Want 后
            // SharePlugin.handleWant 用 systemShare.getSharedData 还原图片。
            "actions": [
              "ohos.want.action.sendData"
            ],
            "uris": [
              {
                "scheme": "file",
                "utd": "general.image",
                "maxFileSupported": 9
              }
            ]
          },
          {
            // 深链：通知与服务卡片点击均进入统一 Flutter 路由。
            "actions": [
              "ohos.want.action.viewData"
            ],
            "uris": [
              {
                "scheme": "freshcue"
              }
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "FreshCueFormAbility",
        "srcEntry": "./ets/form/FreshCueFormAbility.ets",
        "label": "$string:freshcue_form_name",
        "description": "$string:freshcue_form_desc",
        "type": "form",
        "metadata": [
          {
            "name": "ohos.extension.form",
            "resource": "$profile:form_config"
          }
        ]
      }
    ],
    // 网络只用于用户主动下载离线 OCR 模型。
    "requestPermissions": [
      {
        // 代理提醒：安装期授予（system_grant）。
        "name": "ohos.permission.PUBLISH_AGENT_REMINDER"
      },
      {
        // 仅在用户选择“系统日程”后申请。
        "name": "ohos.permission.READ_CALENDAR",
        "reason": "$string:calendar_permission_reason",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      },
      {
        // 用于创建并同步用户选择的系统日程。
        "name": "ohos.permission.WRITE_CALENDAR",
        "reason": "$string:calendar_permission_reason",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      },
      {
        // 截图和识别内容不上传。
        "name": "ohos.permission.INTERNET"
      }
    ]
  }
}
